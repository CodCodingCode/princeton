# Copy to .env.local and fill in.
# Backend URL for the Next.js proxy (default: http://localhost:8000).
NEOVAX_BACKEND_URL=http://localhost:8000

# Google Maps JavaScript API key (client-side) — used by TrialMap.
# Leave unset to get a text-only fallback list of trial sites.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
